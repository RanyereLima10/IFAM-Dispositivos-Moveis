import React, { useState } from 'react';
import {
  View,
  Text,
  TextInput,
  TouchableOpacity,
  StyleSheet
} from 'react-native';

export default function App() {
  const [saldo, setSaldo] = useState('');
  const [saque, setSaque] = useState('');
  const [resultado, setResultado] = useState('');

  const realizarSaque = () => {
    try {
      const saldoAtual = Number(saldo);
      const valorSaque = Number(saque);

      if (isNaN(saldoAtual) || isNaN(valorSaque)) {
        throw new Error('Informe valores válidos.');
      }

      if (saldoAtual <= 0) {
        throw new Error('Saldo inválido.');
      }

      if (valorSaque <= 0) {
        throw new Error('Valor de saque inválido.');
      }

      if (valorSaque > saldoAtual) {
        throw new Error('Saldo insuficiente.');
      }

      const saldoFinal = saldoAtual - valorSaque;

      setResultado(
        `Saque realizado com sucesso.\nSaldo restante: R$ ${saldoFinal.toFixed(2)}`
      );

    } catch (erro) {
      setResultado(erro.message);
    } finally {
      console.log('Operação encerrada.');
    }
  };

  return (
    <View style={styles.container}>
      <Text style={styles.titulo}>Saque Bancário</Text>

      <TextInput
        placeholder="Saldo"
        keyboardType="numeric"
        value={saldo}
        onChangeText={setSaldo}
        style={styles.input}
      />

      <TextInput
        placeholder="Valor do saque"
        keyboardType="numeric"
        value={saque}
        onChangeText={setSaque}
        style={styles.input}
      />

      <TouchableOpacity
        style={styles.botao}
        onPress={realizarSaque}
      >
        <Text style={styles.textoBotao}>Sacar</Text>
      </TouchableOpacity>

      <Text style={styles.resultado}>{resultado}</Text>
    </View>
  );
}

const styles = StyleSheet.create({
  container: { padding: 20, marginTop: 60 },
  titulo: { fontSize: 24, fontWeight: 'bold', marginBottom: 20 },
  input: {
    borderWidth: 1,
    padding: 12,
