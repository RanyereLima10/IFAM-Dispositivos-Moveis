Descrição:O código foi desenvolvido em React Native com Expo para criar uma tela responsiva de cursos.
A aplicação possui uma imagem no topo, título, subtítulo, cards coloridos com ícones e um botão na parte inferior.
Os cards são gerados dinamicamente através de um array utilizando o método `map()`, facilitando a organização do conteúdo. 
O layout utiliza Flexbox para deixar os elementos responsivos em diferentes tamanhos de tela.
Também foram adicionadas novas cores, mais 4 cards, ícones personalizados e um botão interativo para melhorar o visual e a experiência do usuário.

************+***************************************************************************+***************************************************************************+********************************************

// Importa a biblioteca do React para permitir o uso de JSX e componentes
import React from 'react';

// Importa os componentes nativos do React Native para estruturar a tela
import {
  View,           // Bloco de layout (como uma <div> no HTML)
  Text,           // Componente para renderizar textos (como <p> ou <h1>)
  StyleSheet,     // Ferramenta para criar as estilizações (CSS-in-JS)
  ScrollView,     // Container que permite rolagem na tela quando o conteúdo transborda
  TouchableOpacity, // Botão clicável que reduz a opacidade ao ser tocado
  Image,          // Componente para exibir imagens na tela
} from 'react-native';

// Importa pacotes de ícones vetoriais fornecidos pelo Expo
import { MaterialIcons, FontAwesome5 } from '@expo/vector-icons';

// Define e exporta como padrão o componente funcional principal chamado App
export default function App() {
  
  // Cria uma lista de objetos (array) para armazenar os dados de cada card
  const cards = [
    { titulo: 'HTML', cor: '#6C63FF', icone: 'code' },
    { titulo: 'CSS', cor: '#FF9800', icone: 'brush' },
    { titulo: 'JavaScript', cor: '#4CAF50', icone: 'javascript' },
    { titulo: 'React Native', cor: '#2196F3', icone: 'mobile-alt' },
    { titulo: 'Banco de Dados', cor: '#9C27B0', icone: 'storage' },
    { titulo: 'API', cor: '#009688', icone: 'cloud' },
    { titulo: 'Deploy', cor: '#E91E63', icone: 'rocket' },
    { titulo: 'UX Design', cor: '#795548', icone: 'palette' },
  ];

  // Retorna a estrutura visual em JSX que será renderizada na tela
  return (
    // Abre a área de rolagem aplicando os estilos específicos para o container de conteúdo
    <ScrollView contentContainerStyle={styles.container}>
      
      {/* IMAGEM TOPO */}
      {/* Renderiza uma imagem externa através do link fornecido na propriedade uri */}
      <Image
        source={{
          uri: 'https://cdn-icons-png.flaticon.com/512/2721/2721297.png',
        }}
        style={styles.imagem} // Aplica o estilo de tamanho e margens da imagem
      />

      {/* Renderiza o título principal do aplicativo com estilo em negrito e cor escura */}
      <Text style={styles.titulo}>Aprendendo Juntos</Text>
      
      {/* Renderiza o subtítulo explicativo com estilo de cor cinza e centralizado */}
      <Text style={styles.subtitulo}>
        Cursos e conteúdos para impulsionar seus estudos
      </Text>

      {/* Container que agrupa e organiza a exibição dos cards em linha */}
      <View style={styles.cardsContainer}>
        {/* Percorre o array de dados 'cards' para gerar um elemento visual para cada item */}
        {cards.map((card, index) => (
          // Cria a caixa do card usando um ID único (key) e combinando estilos fixos com a cor dinâmica do objeto
          <View
            key={index}
            style={[styles.card, { backgroundColor: card.cor }]}
          >
            {/* Desenha o ícone do card usando a biblioteca FontAwesome5 com tamanho 30 e cor branca */}
            <FontAwesome5 name={card.icone} size={30} color="#fff" />
            
            {/* Exibe o nome da tecnologia do card atualizado com texto em branco e negrito */}
            <Text style={styles.cardTexto}>{card.titulo}</Text>
          </View>
        ))}
      </View>

      {/* BOTÃO 1 - COMEÇAR */}
      {/* Cria a área clicável para o botão principal de início */}
      <TouchableOpacity style={styles.botao}>
        {/* Adiciona o ícone de foguete antes do texto */}
        <MaterialIcons name="rocket-launch" size={22} color="#fff" />
        {/* Adiciona o texto interno em caixa alta */}
        <Text style={styles.botaoTexto}> COMEÇAR AGORA</Text>
      </TouchableOpacity>

      {/* BOTÃO 2 - PERFIL */}
      {/* Cria o botão combinando a estrutura padrão com uma cor secundária específica */}
      <TouchableOpacity style={[styles.botao, styles.botaoSecundario]}>
        {/* Adiciona o ícone de usuário */}
        <MaterialIcons name="person" size={22} color="#fff" />
        {/* Adiciona o texto do perfil */}
        <Text style={styles.botaoTexto}> MEU PERFIL</Text>
      </TouchableOpacity>

      {/* BOTÃO 3 - SUPORTE */}
      {/* Cria o botão combinando a estrutura padrão com uma cor cinza e margem inferior */}
      <TouchableOpacity style={[styles.botao, styles.botaoSuporte]}>
        {/* Adiciona o ícone de interrogação/ajuda */}
        <MaterialIcons name="help" size={22} color="#fff" />
        {/* Adiciona o texto de suporte */}
        <Text style={styles.botaoTexto}> SUPORTE</Text>
      </TouchableOpacity>
      
    </ScrollView> // Fecha o bloco de rolagem da tela
  );
}

