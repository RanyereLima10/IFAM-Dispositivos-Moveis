import React, { useState } from 'react';

// Importação dos componentes do React Native
import {
  View,
  Text,
  TextInput,
  TouchableOpacity,
  FlatList,
  StyleSheet,
  Alert,
  ScrollView
} from 'react-native';

// Componente principal do aplicativo
export default function App() {

  // Estado que armazena todos os produtos cadastrados
  const [produtos, setProdutos] = useState([]);

  // Estado para armazenar o nome do produto
  const [nome, setNome] = useState('');

  // Estado para armazenar o preço do produto
  const [preco, setPreco] = useState('');

  // Estado para armazenar a categoria do produto
  const [categoria, setCategoria] = useState('');

  // Estado para armazenar a descrição do produto
  const [descricao, setDescricao] = useState('');

  // Estado usado para identificar se um produto está sendo editado
  const [editandoId, setEditandoId] = useState(null);

  // Função responsável por limpar os campos do formulário
  const limparCampos = () => {

    // Limpa o campo nome
    setNome('');

    // Limpa o campo preço
    setPreco('');

    // Limpa o campo categoria
    setCategoria('');

    // Limpa o campo descrição
    setDescricao('');

    // Remove o modo de edição
    setEditandoId(null);
  };

  // Função responsável pela validação dos campos
  const validarCampos = () => {

    // Verifica se algum campo está vazio
    if (!nome || !preco || !categoria || !descricao) {

      // Exibe alerta de erro
      Alert.alert('Erro', 'Todos os campos são obrigatórios!');

      // Retorna falso
      return false;
    }

    // Verifica se o preço é inválido
    if (isNaN(preco) || Number(preco) <= 0) {

      // Exibe alerta de erro
      Alert.alert('Erro', 'Digite um preço válido!');

      // Retorna falso
      return false;
    }

    // Retorna verdadeiro se estiver tudo correto
    return true;
  };

  // Função responsável por salvar ou editar produto
  const salvarProduto = () => {

    // Chama a validação
    if (!validarCampos()) return;

    // Cria um objeto com os dados do produto
    const novoProduto = {

      // Se estiver editando usa o ID atual
      // Caso contrário cria um novo ID
      id: editandoId ? editandoId : Date.now().toString(),

      // Nome do produto
      nome,

      // Preço do produto
      preco,

      // Categoria do produto
      categoria,

      // Descrição do produto
      descricao
    };

    // Verifica se está editando
    if (editandoId) {

      // Percorre a lista de produtos
      const listaAtualizada = produtos.map((produto) =>

        // Substitui o produto editado
        produto.id === editandoId ? novoProduto : produto
      );

      // Atualiza a lista de produtos
      setProdutos(listaAtualizada);

      // Exibe mensagem de sucesso
      Alert.alert('Sucesso', 'Produto atualizado!');
    } else {

      // Adiciona novo produto na lista
      setProdutos([...produtos, novoProduto]);

      // Exibe mensagem de sucesso
      Alert.alert('Sucesso', 'Produto cadastrado!');
    }

    // Limpa os campos após salvar
    limparCampos();
  };

  // Função para deletar produto
  const deletarProduto = (id) => {

    // Cria nova lista sem o produto deletado
    const novaLista = produtos.filter((produto) => produto.id !== id);

    // Atualiza a lista de produtos
    setProdutos(novaLista);
  };

  // Função responsável por carregar dados no formulário
  const editarProduto = (produto) => {

    // Preenche o campo nome
    setNome(produto.nome);

    // Preenche o campo preço
    setPreco(produto.preco);

    // Preenche o campo categoria
    setCategoria(produto.categoria);

    // Preenche o campo descrição
    setDescricao(produto.descricao);

    // Define o ID do produto que está sendo editado
    setEditandoId(produto.id);
  };

  // Retorno da interface do aplicativo
  return (

