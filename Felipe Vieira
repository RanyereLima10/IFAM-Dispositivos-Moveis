import {
  Image,          // Componente para exibir imagens
  ScrollView,     // Container com rolagem de tela
  StyleSheet,     // Utilitário para criar estilos CSS
  Text,           // Componente para textos
  TouchableOpacity, // Botão com efeito de clique transparente
  View            // Bloco container base (como uma div)
} from 'react-native';

export default function App() {
  // Lista de objetos com os dados de cada card
  const cards = [
    { id: 1, title: 'HTML', icon: '🌐', color: '#07335F' },
    { id: 2, title: 'CSS', icon: '🎨', color: '#6C5CE7' },
    { id: 3, title: 'JavaScript', icon: '💻', color: '#E8BD3A' },
    { id: 4, title: 'React', icon: '⚛️', color: '#8CBEEF' },
    { id: 5, title: 'Node.js', icon: '🟢', color: '#428072' },
    { id: 6, title: 'Banco de Dados', icon: '🗄️', color: '#FD79A8' },
  ];

  return (
    // ScrollView permite rolar a tela se o conteúdo for maior que ela
    <ScrollView contentContainerStyle={styles.container}>
      
      {/* Imagem do topo carregada através de um link da web */}
      <Image
        source={{
          uri: 'https://cdn-icons-png.flaticon.com/512/1055/1055687.png',
        }}
        style={styles.image}
      />

      {/* Textos principais da interface */}
      <Text style={styles.title}>Aprendendo React Native</Text>
      <Text style={styles.subtitle}>
        Layout responsivo com cards
      </Text>

      {/* Bloco principal que agrupa todos os cards */}
      <View style={styles.cardsContainer}>
        {/* Percorre o array e cria um componente visual para cada card */}
        {cards.map((card) => (
          <View
            key={card.id} // Identificador único exigido pelo React
            style={[styles.card, { backgroundColor: card.color }]} // Junta o estilo fixo com a cor dinâmica
          >
            <Text style={styles.icon}>{card.icon}</Text>
            <Text style={styles.cardText}>{card.title}</Text>
          </View>
        ))}
      </View>

      {/* Botão clicável */}
      <TouchableOpacity style={styles.button}>
        <Text style={styles.buttonText}>COMEÇAR AGORA</Text>
      </TouchableOpacity>

    </ScrollView>
  );
}

