        {/* Campo email com estado */}
        <TextInput
          style={styles.input}
          placeholder="E-mail"
          value={email}
          onChangeText={setEmail}
        />

        {/* Botão */}
        <TouchableOpacity style={styles.botao}>
          <Text style={styles.textoBotao}>Inscreva-se</Text>
        </TouchableOpacity>

        {/* Se for válido mostra ✔️ */}
        <Text style={{ color: 'green', marginTop: 10 }}>
          {valido ? '✔️' : ''}
        </Text>

      </View>

    </View>
  );
}

