import React, { useState } from 'react';
import { Text, View, TouchableOpacity, StyleSheet, StatusBar } from 'react-native';

export default function App() {
  const [ativo, setAtivo] = useState(false);

  return (
    <View style={styles.container}>
      <StatusBar barStyle="dark-content" />
      
      {/* Lógica Condicional: O texto muda baseado no estado 'ativo' */}
      <Text style={styles.titulo}>
        {ativo ? " Parabéns!" : "Seja bem-vindo, aluno!"}
      </Text>
      
      <Text style={styles.subtitulo}>
        {ativo ? "Você dominou o useState do React Native." : "Clique no botão abaixo para interagir."}
      </Text>

      {/* TouchableOpacity permite criar botões muito mais bonitos que o Button padrão */}
      <TouchableOpacity 
        style={[styles.botao, ativo && styles.botaoAtivo]} 
        onPress={() => setAtivo(!ativo)}
      >
        <Text style={styles.textoBotao}>
          {ativo ? "VOLTAR AO INÍCIO" : "ATIVAR DESAFIO"}
        </Text>
      </TouchableOpacity>
    </View>
  );
}

