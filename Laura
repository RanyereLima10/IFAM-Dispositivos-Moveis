  },
  erro: {
    color: 'red', // Cor vermelha para indicar erro
    marginBottom: 10 // Espaçamento abaixo da mensagem de erro
  },
  sucesso: {
    color: 'green', // Cor verde para indicar sucesso
    marginTop: 15, // Espaçamento acima da mensagem
    fontSize: 16 // Tamanho da fonte da mensagem de sucesso
