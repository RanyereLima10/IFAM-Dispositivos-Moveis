import React, { useState } from 'react';
import {
  View,
  Text,
  TextInput,
  TouchableOpacity,
  FlatList,
  Alert,
  StyleSheet,
} from 'react-native';

export default function App() {

  /* ==================================================
     ESTADOS DO FORMULÁRIO
  ================================================== */
  const [nome, setNome] = useState('');
  const [preco, setPreco] = useState('');
  const [categoria, setCategoria] = useState('Eletrônicos');
  const [descricao, setDescricao] = useState('');

  /* ==================================================
     LISTA DE PRODUTOS
  ================================================== */
  const [produtos, setProdutos] = useState([]);

  /* ==================================================
     CONTROLA QUAL PRODUTO ESTÁ SENDO EDITADO
  ================================================== */
  const [produtoEditando, setProdutoEditando] = useState(null);

  /* ==================================================
     CADASTRAR OU ATUALIZAR PRODUTO
  ================================================== */
  const salvarProduto = () => {
    if (
      nome.trim() === '' ||
      preco.trim() === '' ||
      descricao.trim() === ''
    ) {
      Alert.alert(
        'Erro',
        'Preencha todos os campos obrigatórios.'
      );
      return;
    }

    if (produtoEditando) {
      const listaAtualizada = produtos.map((item) =>
        item.id === produtoEditando
          ? { ...item, nome, preco, categoria, descricao }
          : item
      );

      setProdutos(listaAtualizada);
      Alert.alert('Sucesso', 'Produto atualizado com sucesso!');
      setProdutoEditando(null);
    } else {
      const novoProduto = {
        id: Date.now().toString(),
        nome,
        preco,
        categoria,
        descricao,
      };

      setProdutos([...produtos, novoProduto]);
      Alert.alert('Sucesso', 'Produto cadastrado com sucesso!');
    }

    limparCampos();
  };

  /* ==================================================
     CARREGAR PRODUTO PARA EDIÇÃO
  ================================================== */
  const editarProduto = (produto) => {
    setNome(produto.nome);
    setPreco(produto.preco);
    setCategoria(produto.categoria);
    setDescricao(produto.descricao);
    setProdutoEditando(produto.id);
  };

  /* ==================================================
     EXCLUIR PRODUTO
  ================================================== */
  const excluirProduto = (id) => {
    const novaLista = produtos.filter((item) => item.id !== id);
    setProdutos(novaLista);

    if (produtoEditando === id) {
      limparCampos();
    }
  };

  /* ==================================================
     LIMPAR FORMULÁRIO
  ================================================== */
  const limparCampos = () => {
    setNome('');
    setPreco('');
    setCategoria('Eletrônicos');
    setDescricao('');
    setProdutoEditando(null);
  };

  /* ==================================================
     CARD DE PRODUTO
  ================================================== */
  const renderItem = ({ item }) => (
    <View style={styles.card}>
      <Text style={styles.nomeProduto}>{item.nome}</Text>
      <Text style={styles.precoProduto}>R$ {item.preco}</Text>
      <Text style={styles.infoProduto}>Categoria: {item.categoria}</Text>
      <Text style={styles.infoProduto}>{item.descricao}</Text>

      <View style={styles.areaBotoesCard}>
        <TouchableOpacity
          style={styles.botaoEditar}
          onPress={() => editarProduto(item)}
        >
          <Text style={styles.textoBotaoCard}>EDITAR</Text>
        </TouchableOpacity>

        <TouchableOpacity
          style={styles.botaoExcluir}
          onPress={() => excluirProduto(item.id)}
        >
          <Text style={styles.textoBotaoCard}>EXCLUIR</Text>
        </TouchableOpacity>
      </View>
    </View>
  );

  /* ==================================================
     CABEÇALHO DA LISTA (FORMULÁRIO)
  ================================================== */
  const renderHeader = () => (
    <View>
      <Text style={styles.titulo}>Cadastro de Produtos</Text>

      <Text style={styles.label}>Nome do Produto *</Text>
      <TextInput
        style={styles.input}
        placeholder="Digite o nome"
        placeholderTextColor="#888"
        value={nome}
        onChangeText={setNome}
      />

      <Text style={styles.label}>Preço *</Text>
      <TextInput
        style={styles.input}
        placeholder="Digite o preço"
        placeholderTextColor="#888"
        keyboardType="numeric"
        value={preco}
        onChangeText={setPreco}
      />

      <Text style={styles.label}>Categoria *</Text>
      <View style={styles.categorias}>
        <TouchableOpacity
          style={[
            styles.categoria,
            categoria === 'Eletrônicos' && styles.categoriaSelecionada,
          ]}
          onPress={() => setCategoria('Eletrônicos')}
        >
          <Text style={[
            styles.textoCategoria,
            categoria === 'Eletrônicos' && styles.textoCategoriaSelecionada
          ]}>
            Eletrônicos
          </Text>
        </TouchableOpacity>

        <TouchableOpacity
          style={[
            styles.categoria,
            categoria === 'Roupas' && styles.categoriaSelecionada,
          ]}
          onPress={() => setCategoria('Roupas')}
        >
          <Text style={[
            styles.textoCategoria,
            categoria === 'Roupas' && styles.textoCategoriaSelecionada
          ]}>
            Roupas
          </Text>
        </TouchableOpacity>

        <TouchableOpacity
          style={[
            styles.categoria,
            categoria === 'Alimentos' && styles.categoriaSelecionada,
          ]}
          onPress={() => setCategoria('Alimentos')}
        >
          <Text style={[
            styles.textoCategoria,
            categoria === 'Alimentos' && styles.textoCategoriaSelecionada
          ]}>
            Alimentos
          </Text>
        </TouchableOpacity>
      </View>

      <Text style={styles.label}>Descrição *</Text>
      <TextInput
        style={[styles.input, styles.inputDescricao]}
        multiline
        value={descricao}
        onChangeText={setDescricao}
        placeholder="Digite a descrição"
        placeholderTextColor="#888"
      />

      <TouchableOpacity style={styles.botaoSalvar} onPress={salvarProduto}>
        <Text style={styles.textoBotaoPrincipal}>
          {produtoEditando ? 'ATUALIZAR' : 'CADASTRAR'}
        </Text>
      </TouchableOpacity>

      <TouchableOpacity style={styles.botaoLimpar} onPress={limparCampos}>
        <Text style={styles.textoBotaoSecundario}>LIMPAR</Text>
      </TouchableOpacity>

      <Text style={styles.subtitulo}>Produtos Cadastrados</Text>
    </View>
  );

  return (
    <FlatList
      style={styles.container}
      contentContainerStyle={styles.contentContainer}
      data={produtos}
      keyExtractor={(item) => item.id}
      renderItem={renderItem}
      ListHeaderComponent={renderHeader}
      showsVerticalScrollIndicator={false}
      ListEmptyComponent={
        <Text style={styles.vazio}>Nenhum produto cadastrado</Text>
      }
    />
  );
}

