O sistema deve exibir o saldo disponível, permitir que o usuário informe o valor do saque e validar.
A operação utilizando `try`, `catch`, `throw` e `finally`.
Caso o valor seja inválido ou maior que o saldo disponível, uma mensagem de erro deve ser exibida.
Se o saque for realizado com sucesso, o saldo será atualizado e mostrado ao usuário.
**********************************************************************/
import React, { useState } from 'react';
import {
  View,
  Text,
  TextInput,
  TouchableOpacity,
  Alert,
  StyleSheet
} from 'react-native';

export default function App() {
  const [saldo, setSaldo] = useState(1000);
  const [saque, setSaque] = useState('');
  const [historico, setHistorico] = useState('');

  const realizarSaque = () => {
    try {
      const valor = Number(saque);

      if (isNaN(valor)) {
        throw new Error('Digite apenas números.');
      }

      if (valor <= 0) {
        throw new Error('O valor deve ser maior que zero.');
      }

      if (valor > saldo) {
        throw new Error('Saldo insuficiente.');
      }

      const novoSaldo = saldo - valor;

      setSaldo(novoSaldo);

      setHistorico(
        `Saldo anterior: R$ ${saldo}\n` +
        `Valor sacado: R$ ${valor}\n` +
        `Saldo atual: R$ ${novoSaldo}`
      );

      setSaque('');

      Alert.alert('Sucesso', 'Saque realizado com sucesso!');
    } catch (erro) {
      Alert.alert('Erro', erro.message);
    } finally {
      console.log('Operação encerrada.');
    }
  };

  return (
    <View style={styles.container}>
      <Text style={styles.titulo}> Banco Digital</Text>

      <Text style={styles.saldo}>
        Saldo Atual: R$ {saldo.toFixed(2)}
      </Text>

      <TextInput
        style={styles.input}
        placeholder="Digite o valor do saque"
        keyboardType="numeric"
        value={saque}
        onChangeText={setSaque}
      />

      <TouchableOpacity
        style={styles.botao}
        onPress={realizarSaque}
      >
        <Text style={styles.textoBotao}>Realizar Saque</Text>
      </TouchableOpacity>

      {historico !== '' && (
        <View style={styles.caixaHistorico}>
          <Text style={styles.tituloHistorico}>
            Última Operação
          </Text>
          <Text>{historico}</Text>
        </View>
      )}
    </View>
  );
}

