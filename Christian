import React, { useState } from 'react';
import {
  View,
  Text,
  TextInput,
  TouchableOpacity,
  Alert,
  StyleSheet
} from 'react-native';

export default function App() {
  const [nota, setNota] = useState('');
  const [resultado, setResultado] = useState('');

  const validarNota = () => {
    try {
      const valorNota = Number(nota);

      if (nota === '') {
        throw new Error('Digite uma nota.');
      }

      if (isNaN(valorNota)) {
        throw new Error('Digite apenas números.');
      }

      if (valorNota < 0) {
        throw new Error('A nota não pode ser menor que 0.');
      }

      if (valorNota > 10) {
        throw new Error('A nota não pode ser maior que 10.');
      }

      let situacao = '';

      if (valorNota >= 7) {
        situacao = '✅ Aprovado';
      } else if (valorNota <= 5) {
        situacao = '🟡 Recuperação';
      } else {
        situacao = '❌ Reprovado';
      }

      setResultado(
        `Nota: ${valorNota}\nSituação: ${situacao}`
      );

      Alert.alert('Sucesso', 'Nota válida!');
    } catch (erro) {
      setResultado(`Erro: ${erro.message}`);
      Alert.alert('Erro', erro.message);
    } finally {
      console.log('Validação concluída.');
    }
  };

  return (
    <View style={styles.container}>
      <Text style={styles.titulo}> Sistema Escolar</Text>

      <TextInput
        style={styles.input}
        placeholder="Digite a nota (0 a 10)"
        keyboardType="numeric"
        value={nota}
        onChangeText={setNota}
      />

      <TouchableOpacity
        style={styles.botao}
        onPress={validarNota}
      >
        <Text style={styles.textoBotao}>
          Validar Nota
        </Text>
      </TouchableOpacity>

      {resultado !== '' && (
        <View style={styles.caixaResultado}>
          <Text style={styles.textoResultado}>
            {resultado}
          </Text>
        </View>
      )}
    </View>
  );
}

