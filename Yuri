// Importa o React para criar componentes
import React from 'react';

// Importa componentes do React Native
import {
  View, // Container visual
  Text, // Exibe textos
  StyleSheet, // Cria estilos
  TouchableOpacity, // Botão clicável
  Image, // Exibe imagens
  Dimensions // Pega dimensões da tela
} from 'react-native';

// Exporta o componente principal App
export default function App() {

  // Pega a largura atual da tela do celular
  const larguraTela = Dimensions.get('window').width;

  // Retorna o layout da aplicação
  return (

    // Container principal da tela
    <View style={styles.container}>

      {/* Imagem no topo */}
      <Image

        // Imagem carregada pela internet
        source={{ uri: 'https://picsum.photos/300' }}

        // Aplica estilos fixos + estilos dinâmicos
        style={[
          styles.imagemTopo,
          {

            // Largura da imagem = 40% da tela
            width: larguraTela * 0.4,

            // Altura da imagem = 40% da tela
            height: larguraTela * 0.4
          }
        ]}
      />

      {/* Título principal */}
      <Text style={styles.titulo}>
        Meu Aplicativo
      </Text>

      {/* Subtítulo */}
      <Text style={styles.subtitulo}>
        Layout Responsivo com Cards
      </Text>

      {/* Container que segura todos os cards */}
      <View style={styles.linha}>

        {/* Card Pedra */}
        <View
          style={[
            styles.card,
            {

              // Largura do card = 22% da tela
              width: larguraTela * 0.22,

              // Cor de fundo do card
              backgroundColor: '#4A90E2'
            }
          ]}
        >

          {/* Emoji do card */}
          <Text style={styles.icone}>🗿</Text>

          {/* Texto do card */}
          <Text style={styles.textoCard}>Pedra</Text>

        </View>

        {/* Card Papel */}
        <View
          style={[
            styles.card,
            {
              width: larguraTela * 0.22,
              backgroundColor: '#27AE60'
            }
          ]}
        >
          <Text style={styles.icone}>📜</Text>
          <Text style={styles.textoCard}>Papel</Text>
        </View>

        {/* Card Tesoura */}
        <View
          style={[
            styles.card,
            {
              width: larguraTela * 0.22,
              backgroundColor: '#E67E22'
            }
          ]}
        >
          <Text style={styles.icone}>✂️</Text>
          <Text style={styles.textoCard}>Tesoura</Text>
        </View>

        {/* Card Fogo */}
        <View
          style={[
            styles.card,
            {
              width: larguraTela * 0.22,
              backgroundColor: '#9B59B6'
            }
          ]}
        >
          <Text style={styles.icone}>🔥</Text>
          <Text style={styles.textoCard}>Fogo</Text>
        </View>

        {/* Card Água */}
        <View
          style={[
            styles.card,
            {
              width: larguraTela * 0.22,
              backgroundColor: '#3498DB'
            }
          ]}
        >
          <Text style={styles.icone}>💧</Text>
          <Text style={styles.textoCard}>Água</Text>
        </View>

        {/* Card Raio */}
        <View
          style={[
            styles.card,
            {
              width: larguraTela * 0.22,
              backgroundColor: '#E74C3C'
            }
          ]}
        >
          <Text style={styles.icone}>⚡</Text>
          <Text style={styles.textoCard}>Raio</Text>
        </View>

        {/* Card Estrela */}
        <View
          style={[
            styles.card,
            {
              width: larguraTela * 0.22,
              backgroundColor: '#F1C40F'
            }
          ]}
        >
          <Text style={styles.icone}>🌟</Text>
          <Text style={styles.textoCard}>Estrela</Text>
        </View>

      </View>

      {/* Botão */}
      <TouchableOpacity

        // Estilo do botão
        style={[
          styles.botao,
          {

            // Botão ocupa 70% da largura da tela
            width: larguraTela * 0.7
          }
        ]}
      >

        {/* Texto do botão */}
        <Text style={styles.textoBotao}>
          ENTRAR
        </Text>

      </TouchableOpacity>

    </View>
  );
}

// Criação dos estilos
const styles = StyleSheet.create({

  // Estilo do container principal
  container: {

    // Faz ocupar toda a tela
    flex: 1,

    // Cor de fundo escura
    backgroundColor: '#121212',

    // Centraliza verticalmente
    justifyContent: 'center',

    // Centraliza horizontalmente
    alignItems: 'center',

    // Espaçamento interno
    padding: 15
  },

  // Estilo da imagem
  imagemTopo: {

    // Deixa imagem redonda
    borderRadius: 100,

