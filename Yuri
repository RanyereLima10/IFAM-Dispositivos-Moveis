import React, { useState } from 'react';
import { View, Text, TextInput, Button, StyleSheet } from 'react-native';

export default function App() {

  const [nome, setNome] = useState("");
  const [dataNasc, setDataNasc] = useState("");
  const [mensagem, setMensagem] = useState("");

  // Mostra nome + data de nascimento
  const mostrarDados = () => {

    if (!nome || !dataNasc) {
      setMensagem("Preencha nome e data de nascimento!");
      return;
    }

    setMensagem(`Olá, ${nome}! Você nasceu em ${dataNasc}.`);
  };

  return (
    <View style={styles.container}>

      <Text style={styles.titulo}>Digite seu nome:</Text>

      <TextInput
        style={styles.input}
        placeholder="Nome"
        onChangeText={setNome}
      />

      <Text style={styles.titulo}>Data de nascimento:</Text>

      <TextInput
        style={styles.input}
        placeholder="DD/MM/AAAA"
        onChangeText={setDataNasc}
      />

      <Button title="Enviar" onPress={mostrarDados} />

      <Text style={styles.resultado}>{mensagem}</Text>

    </View>
  );
}

