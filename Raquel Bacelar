import React from 'react';

// Importa componentes do React Native
import { 
  View, // Cria áreas/blocos na tela
  Text, // Exibe textos
  StyleSheet, // Cria estilos CSS-like
  Image, // Exibe imagens
  TouchableOpacity, // Cria botão clicável
  ScrollView // Permite rolar a tela
} from 'react-native';

// Componente principal do aplicativo
export default function App() {

  // Array com os dados dos cards
  const cards = [
    { id: 1, title: 'HTML', icon: '🌐', color: '#07335F' },
    { id: 2, title: 'CSS', icon: '🎨', color: '#6C5CE7' },
    { id: 3, title: 'JavaScript', icon: '💻', color: '#E8BD3A' },
    { id: 4, title: 'React', icon: '⚛️', color: '#8CBEEF' },
    { id: 5, title: 'Node.js', icon: '🟢', color: '#428072' },
    { id: 6, title: 'Banco de Dados', icon: '🗄️', color: '#FD79A8' },
    { id: 6, title: 'API', icon: '🗄️', color: '#8C8C8C' },
    { id: 6, title: 'Deploy', icon: '🗄️', color: '#2E3E4D' },
  ];

  // Retorna tudo que será mostrado na tela
  return (

    // ScrollView permite rolar a página
    <ScrollView contentContainerStyle={styles.container}>
      
      {/* Imagem no topo */}
      <Image

        // Define a imagem usando uma URL da internet
        source={{
          uri: 'https://cdn-icons-png.flaticon.com/512/1055/1055687.png',
        }}

        // Aplica o estilo da imagem
        style={styles.image}
      />

      {/* Título principal */}
      <Text style={styles.title}>
        Aprendendo React Native
      </Text>

      {/* Subtítulo */}
      <Text style={styles.subtitle}>
        Layout responsivo com cards
      </Text>

      {/* Área que contém todos os cards */}
      <View style={styles.cardsContainer}>

        {/* Percorre o array cards e cria um card para cada item */}
        {cards.map((card) => (

          // View representa cada card
          <View
            key={card.id} // Chave única para cada card

            // Junta o estilo padrão do card com a cor específica
            style={[styles.card, { backgroundColor: card.color }]}
          >

            {/* Mostra o emoji do card */}
            <Text style={styles.icon}>
              {card.icon}
            </Text>

            {/* Mostra o nome da tecnologia */}
            <Text style={styles.cardText}>
              {card.title}
            </Text>

          </View>
        ))}
      </View>

      {/* Botão */}
      <TouchableOpacity style={styles.button}>

        {/* Texto do botão */}
        <Text style={styles.buttonText}>
          COMEÇAR AGORA
        </Text>

      </TouchableOpacity>

