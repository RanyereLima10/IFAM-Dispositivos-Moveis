import React, { useState } from 'react';
import {
  View,
  Text,
  TextInput,
  TouchableOpacity,
  Alert,
  StyleSheet,
} from 'react-native';

export default function App() {
  const [saque, setSaque] = useState('');
  const [saldo, setSaldo] = useState(5000);

  const realizarSaque = () => {
    try {
      const valor = Number(saque);

      if (saque === '') {
        throw new Error('Digite um valor para saque.');
      }

      if (isNaN(valor)) {
        throw new Error('Digite apenas números.');
      }

      if (valor <= 0) {
        throw new Error('O valor do saque deve ser maior que zero.');
      }

      if (valor > saldo) {
        throw new Error('Saldo insuficiente para realizar o saque.');
      }

      const novoSaldo = saldo - valor;
      setSaldo(novoSaldo);

      Alert.alert(
        ' Saque realizado',
        `Você sacou R$ ${valor.toFixed(2)}\n\nSaldo restante: R$ ${novoSaldo.toFixed(2)}`
      );

      setSaque('');
    } catch (erro) {
      Alert.alert(' Erro', erro.message);
    } finally {
      console.log('Operação finalizada.');
    }
  };

  return (
    <View style={styles.container}>
      <Text style={styles.titulo}> Banco Digital</Text>

      <Text style={styles.saldo}>
        Saldo Atual: R$ {saldo.toFixed(2)}
      </Text>

      <TextInput
        style={styles.input}
        placeholder="Digite o valor do saque"
        keyboardType="numeric"
        value={saque}
        onChangeText={setSaque}
      />

      <TouchableOpacity
        style={styles.botao}
        onPress={realizarSaque}
      >
        <Text style={styles.textoBotao}>Realizar Saque</Text>
      </TouchableOpacity>
    </View>
  );
}

