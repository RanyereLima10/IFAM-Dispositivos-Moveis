    <View style={{ padding: 20 }}>
      <Text>Digite sua idade:</Text>
      <TextInput
        keyboardType="numeric"
        value={idade}
        onChangeText={setIdade}
        style={{ borderWidth: 1, marginVertical: 10 }}
      />
      <Button title="Verificar" onPress={verificarIdade} />
    </View>
  );
}
