import React, { useState } from "react";
import {
  View,
  Text,
  TextInput,
  TouchableOpacity,
  StyleSheet,
} from "react-native";

export default function App() {
  const [nota, setNota] = useState("");
  const [mensagem, setMensagem] = useState("");
  const [corMensagem, setCorMensagem] = useState("black");

  const validarNota = () => {
    try {
      if (nota.trim() === "") {
        throw new Error(" Digite uma nota!");
      }

      const valor = parseFloat(nota);

      if (isNaN(valor)) {
        throw new Error(" Digite apenas números.");
      }

      if (valor < 0) {
        throw new Error(" A nota não pode ser menor que 0.");
      }

      if (valor > 10) {
        throw new Error(" A nota não pode ser maior que 10.");
      }

      let situacao = "";

      if (valor < 5) {
        situacao = " Reprovado";
        setCorMensagem("red");
      } else if (valor < 7) {
        situacao = " Recuperação";
        setCorMensagem("orange");
      } else {
        situacao = " Aprovado";
        setCorMensagem("green");
      }

      setMensagem(`Nota: ${valor}\nSituação: ${situacao}`);

    } catch (erro) {
      setMensagem(erro.message);
      setCorMensagem("red");
    } finally {
      console.log("Validação concluída.");
    }
  };

  return (
    <View style={styles.container}>
      <Text style={styles.titulo}> Sistema de Notas</Text>

      <TextInput
        style={styles.input}
        placeholder="Digite a nota"
        keyboardType="numeric"
        value={nota}
        onChangeText={setNota}
      />

      <TouchableOpacity
        style={styles.botao}
        onPress={validarNota}
      >
        <Text style={styles.textoBotao}>
          Validar Nota
        </Text>
      </TouchableOpacity>

      {mensagem !== "" && (
        <Text
          style={[
            styles.mensagem,
            { color: corMensagem }
          ]}
        >
          {mensagem}
        </Text>
      )}
    </View>
  );
}

