import React, { useState } from "react";
import {
  View,
  Text,
  TextInput,
  TouchableOpacity,
  FlatList,
  StyleSheet,
  Alert,
  ScrollView,
} from "react-native";

export default function App() {
  // Estado da lista de produtos
  const [produtos, setProdutos] = useState([]);

  // Estados dos campos do formulário
  const [nome, setNome] = useState("");
  const [preco, setPreco] = useState("");
  const [categoria, setCategoria] = useState("");
  const [descricao, setDescricao] = useState("");

  // Controla edição
  const [editandoId, setEditandoId] = useState(null);

  // Função para limpar formulário
  const limparCampos = () => {
    setNome("");
    setPreco("");
    setCategoria("");
    setDescricao("");
    setEditandoId(null);
  };

  // Validação dos dados
  const validarCampos = () => {
    if (!nome || !preco || !categoria || !descricao) {
      Alert.alert("Erro", "Todos os campos são obrigatórios.");
      return false;
    }

    if (isNaN(preco) || Number(preco) <= 0) {
      Alert.alert("Erro", "Digite um preço válido.");
      return false;
    }

    return true;
  };

  // Adicionar ou editar produto
  const salvarProduto = () => {
    if (!validarCampos()) return;

    const novoProduto = {
      id: editandoId ? editandoId : Date.now().toString(),
      nome,
      preco,
      categoria,
      descricao,
    };

    // Se estiver editando
    if (editandoId) {
      const listaAtualizada = produtos.map((produto) =>
        produto.id === editandoId ? novoProduto : produto
      );

      setProdutos(listaAtualizada);

      Alert.alert("Sucesso", "Produto atualizado!");
    } else {
      // Novo cadastro
      setProdutos([...produtos, novoProduto]);

      Alert.alert("Sucesso", "Produto cadastrado!");
    }

    limparCampos();
  };

  // Editar produto
  const editarProduto = (produto) => {
    setNome(produto.nome);
    setPreco(produto.preco);
    setCategoria(produto.categoria);
    setDescricao(produto.descricao);
    setEditandoId(produto.id);
  };

  // Deletar produto
  const deletarProduto = (id) => {
    Alert.alert(
      "Confirmar",
      "Deseja realmente excluir este produto?",
      [
        {
          text: "Cancelar",
          style: "cancel",
        },
        {
          text: "Excluir",
          onPress: () => {
            const novaLista = produtos.filter(
              (produto) => produto.id !== id
            );

            setProdutos(novaLista);
          },
        },
      ]
    );
  };

  // Renderização de cada item da lista
  const renderItem = ({ item }) => (
    <View style={styles.card}>
      <Text style={styles.titulo}>{item.nome}</Text>

      <Text>Preço: R$ {item.preco}</Text>
      <Text>Categoria: {item.categoria}</Text>
      <Text>Descrição: {item.descricao}</Text>

      <View style={styles.botoesContainer}>
        <TouchableOpacity
          style={[styles.botao, styles.botaoEditar]}
          onPress={() => editarProduto(item)}
        >
          <Text style={styles.textoBotao}>Editar</Text>
        </TouchableOpacity>

        <TouchableOpacity
          style={[styles.botao, styles.botaoExcluir]}
          onPress={() => deletarProduto(item.id)}
        >
          <Text style={styles.textoBotao}>Excluir</Text>
        </TouchableOpacity>
      </View>
    </View>
  );

  return (
    <ScrollView style={styles.container}>
      <Text style={styles.header}>
        Cadastro de Produtos
      </Text>

      {/* Campo Nome */}
      <TextInput
        style={styles.input}
        placeholder="Nome do produto"
        value={nome}
        onChangeText={setNome}
      />

      {/* Campo Preço */}
      <TextInput
        style={styles.input}
        placeholder="Preço"
        value={preco}
        onChangeText={setPreco}
        keyboardType="numeric"
      />

      {/* Campo Categoria */}
      <TextInput
        style={styles.input}
        placeholder="Categoria"
        value={categoria}
        onChangeText={setCategoria}
      />

      {/* Campo Descrição */}
      <TextInput
        style={[styles.input, styles.textArea]}
        placeholder="Descrição"
        value={descricao}
        onChangeText={setDescricao}
        multiline
      />

      {/* Botão Salvar */}
      <TouchableOpacity
        style={styles.botaoSalvar}
        onPress={salvarProduto}
      >
        <Text style={styles.textoBotao}>
          {editandoId ? "Atualizar Produto" : "Cadastrar Produto"}
        </Text>
      </TouchableOpacity>

      {/* Lista de Produtos */}
      <Text style={styles.subtitulo}>
        Produtos Cadastrados
      </Text>

      <FlatList
        data={produtos}
        keyExtractor={(item) => item.id}
        renderItem={renderItem}
        scrollEnabled={false}
      />
    </ScrollView>
  );
}

