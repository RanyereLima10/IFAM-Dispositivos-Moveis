import React, { useState } from 'react';
import { View, Text, TextInput, Button, StyleSheet } from 'react-native';

export default function App() {
  const [saldo] = useState(1000);
  const [saque, setSaque] = useState('');
  const [resultado, setResultado] = useState('');

  const realizarSaque = () => {
    try {
      // Converte o valor digitado para número
      const valorSaque = Number(saque);

      // Verifica se o valor é válido
      if (isNaN(valorSaque) || valorSaque <= 0) {
        throw new Error('Digite um valor válido para saque.');
      }

      // Verifica se há saldo suficiente
      if (valorSaque > saldo) {
        throw new Error('Saldo insuficiente.');
      }

      const novoSaldo = saldo - valorSaque;

      setResultado(
        `Saque realizado com sucesso!\nSaldo restante: R$ ${novoSaldo}`
      );
    } catch (erro) {
      setResultado(`Erro: ${erro.message}`);
    } finally {
      console.log('Operação encerrada.');
    }
  };

  return (
    <View style={styles.container}>
      <Text style={styles.titulo}>Saque Bancário</Text>

      <Text style={styles.saldo}>Saldo disponível: R$ {saldo}</Text>

      <TextInput
        style={styles.input}
        placeholder="Valor do saque"
        keyboardType="numeric"
        value={saque}
        onChangeText={setSaque}
      />

      <Button title="Sacar" onPress={realizarSaque} />

      <Text style={styles.resultado}>{resultado}</Text>
    </View>
  );
}

