import React, { useState } from 'react';
import {
  View,
  Text,
  TextInput,
  Button,
  StyleSheet,
} from 'react-native';

export default function App() {

  const [mensagem, setMensagem] = useState("Boa sorte");
  const [msg, setMsg] = useState("Boa sorte");
  const [nome, setNome] = useState('');
  const [alerta, setAlerta] = useState('');

  function mostrarMensagem() {
    if (nome === '') {
      setMensagem('Digite seu nome!');
    } else {
      setMensagem('Olá, ' + nome + '! Seja bem-vindo 😊');
    }
  }

  function mudarMensagem() {
    if (msg === "Nunca desista dos seus objetivos!") {
      setMsg('Boa sorte');
    } else {
      setMsg('Nunca desista dos seus objetivos!');
    }
  }

  function mostrarAlerta() {
    if (alerta === '') {
      setAlerta('Botão clicado');
    }
  }

  return (
    <View style={styles.container}>

      <Text style={styles.titulo}>
        Meu Primeiro App
      </Text>

      <Text style={styles.alerta}>
        {alerta}
      </Text>

      <Text style={styles.texto}>
        Nome do aluno: Bruno Guilherme
      </Text>

      <Text style={styles.texto}>
        Curso: Informática
      </Text>

      <Text style={styles.motivacao}>
        {msg}
      </Text>

      <View style={styles.botoes}>
        <Button
          title="Mudar mensagem"
          onPress={mudarMensagem}
        />
      </View>

      <TextInput
        style={styles.input}
        placeholder="Digite seu nome"
        onChangeText={setNome}
      />

      <View style={styles.botoes}>
        <Button
          title="Mostrar mensagem"
          onPress={mostrarMensagem}
        />

        <Button
          title="Mostrar alerta"
          onPress={mostrarAlerta}
        />
      </View>

      <Text style={styles.resultado}>
        {mensagem}
      </Text>

    </View>
  );
}

const styles = StyleSheet.create({

  container: {
    flex: 1,
    justifyContent: 'center',
    padding: 20,
    backgroundColor: '#d0ebff'
  },

  titulo: {
    fontSize: 26,
    fontWeight: 'bold',
    marginBottom: 15,
    textAlign: 'center',
    color: '#003366'
  },

  texto: {
    fontSize: 16,
    marginBottom: 5,
    textAlign: 'center'
  },

  alerta: {
    color: '#FF0000',
    fontSize: 25,
    textAlign: 'center'
  },

  motivacao: {
    fontStyle: 'italic',
    marginBottom: 15,
    textAlign: 'center',
    color: '#555'
  },

  input: {
    borderWidth: 1,
    borderColor: '#999',
    padding: 10,
    marginVertical: 10,
    borderRadius: 8,
    backgroundColor: '#fff'
  },

  botoes: {
    marginVertical: 10
  },

  resultado: {
    marginTop: 15,
    fontSize: 18,
    color: 'blue',
    textAlign: 'center'
  }

});

