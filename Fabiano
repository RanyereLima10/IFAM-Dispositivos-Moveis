              numberOfLines={3}
            />

            {/* Botão Cadastrar/Atualizar */}
            <TouchableOpacity style={styles.botaoCadastrar} onPress={cadastrarProduto}>
              <Text style={styles.textoBotao}>
                {editandoId ? 'ATUALIZAR PRODUTO' : 'CADASTRAR PRODUTO'}
              </Text>
            </TouchableOpacity>

            {/* Botão Limpar */}
            <TouchableOpacity style={styles.botaoLimpar} onPress={limparCampos}>
              <Text style={styles.textoBotao}>LIMPAR CAMPOS</Text>
            </TouchableOpacity>

