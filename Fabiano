      Alert.alert('Erro', 'O nome deve ter no mínimo 3 caracteres.');
      return false;
    }

    if (!preco || isNaN(preco.replace(',', '.')) || parseFloat(preco.replace(',', '.')) <= 0) {
      Alert.alert('Erro', 'Digite um preço válido maior que 0.');
      return false;
    }

    if (!categoria) {
      Alert.alert('Erro', 'Selecione uma categoria.');
      return false;
    }

    return true;
  };

  // ============================================================================
  // FUNÇÃO: LIMPAR CAMPOS
  // ============================================================================

  const limparCampos = () => {
    setNome('');
    setPreco('');
    setCategoria('Perfumaria');
    setDescricao('');
    setEditandoId(null);
  };

  // ============================================================================
  // FUNÇÃO: CADASTRAR OU ATUALIZAR PRODUTO
  // ============================================================================

  const cadastrarProduto = () => {
    if (!validarFormulario()) {
      return;
    }

    const precoFormatado = parseFloat(preco.replace(',', '.'));

    const novoProduto = {
      id: editandoId || Date.now().toString(),
      nome: nome.trim(),
      preco: precoFormatado.toFixed(2),
      categoria,
      descricao: descricao.trim(),
    };

    if (editandoId) {
      const listaAtualizada = produtos.map((item) =>
        item.id === editandoId ? novoProduto : item
      );
      setProdutos(listaAtualizada);
      Alert.alert('Sucesso', 'Produto atualizado com sucesso!');
    } else {
      setProdutos([...produtos, novoProduto]);
      Alert.alert('Sucesso', 'Produto cadastrado com sucesso!');
    }

    limparCampos();
  };

  // ============================================================================
  // FUNÇÃO: EDITAR PRODUTO
  // ============================================================================

  const editarProduto = (produto) => {
    setNome(produto.nome);
    setPreco(produto.preco.toString());
    setCategoria(produto.categoria);
    setDescricao(produto.descricao);
    setEditandoId(produto.id);
  };

  // ============================================================================
  // FUNÇÃO: DELETAR PRODUTO
  // ============================================================================

  const deletarProduto = (id) => {
    Alert.alert(
      'Confirmar Exclusão',
      'Deseja realmente excluir este produto?',
      [
        { text: 'Cancelar', style: 'cancel' },
        {
          text: 'Excluir',
          style: 'destructive',
          onPress: () => {
            const novaLista = produtos.filter((item) => item.id !== id);
            setProdutos(novaLista);
            Alert.alert('Sucesso', 'Produto removido com sucesso!');
            if (editandoId === id) limparCampos();
          },
        },
      ]
    );
  };

  const categorias = ['Perfumaria', 'Maquiagem', 'Cosmético', 'Outros'];

  // ============================================================================
  // TELA 1: MENU INICIAL
  // ============================================================================
  if (tela === 'inicio') {
    return (
      <SafeAreaView style={styles.containerBoasVindas}>
        <View style={styles.cardBoasVindas}>
          <Text style={styles.tituloPrincipal}>⚱ Produtos da Natura 𖠞༄</Text>
          <Text style={styles.subtituloPrincipal}></Text>
          
          <TouchableOpacity 
            style={styles.botaoEntrar} 
            onPress={() => setTela('cadastro')}
          >
            <Text style={styles.textoBotao}>ACESSAR SISTEMA</Text>
          </TouchableOpacity>
        </View>
      </SafeAreaView>
    );
  }

  // ============================================================================
  // TELA 2: FORMULÁRIO E LISTAGEM
  // ============================================================================
  return (
    <SafeAreaView style={styles.container}>
      
      {/* HEADER */}
      <View style={styles.header}>
        <Text style={styles.titulo}>⚱ Produtos da Natura 𖠞༄</Text>
        <Text style={styles.subtitulo}>
          Aqui você encontra produtos de perfumaria, maquiagem e cosméticos em geral com o melhor da tecnologia, ciência e natureza para seus cuidados diários.
        </Text>
      </View>

      {/* LISTA DE PRODUTOS COMPLETA COM O FORMULÁRIO NO HEADER DA FLATLIST */}
      <FlatList
        data={produtos}
        keyExtractor={(item) => item.id}
        showsVerticalScrollIndicator={false}
        ListHeaderComponent={
          <View style={styles.formulario}>
            {/* Nome */}
            <Text style={styles.label}>Nome do Produto *</Text>
            <TextInput
              style={styles.input}
              placeholder="Digite o nome do produto"
              placeholderTextColor="#999"
              value={nome}
              onChangeText={setNome}
            />

            {/* Preço */}
            <Text style={styles.label}>Preço *</Text>
            <TextInput
              style={styles.input}
              placeholder="Digite o preço (ex: 99.90)"
              placeholderTextColor="#999"
              value={preco}
              onChangeText={setPreco}
              keyboardType="numeric"
            />

            {/* Categoria */}
            <Text style={styles.label}>Categoria *</Text>
            <View style={styles.categoriaContainer}>
              {categorias.map((item) => (
                <TouchableOpacity
                  key={item}
                  style={[
                    styles.categoriaBotao,
                    categoria === item && styles.categoriaSelecionada,
                  ]}
                  onPress={() => setCategoria(item)}
                >
                  <Text
                    style={[
                      styles.categoriaTexto,
                      categoria === item && styles.categoriaTextoSelecionado,
                    ]}
                  >
                    {item}
                  </Text>
                </TouchableOpacity>
              ))}
            </View>

            {/* Descrição */}
            <Text style={styles.label}>Descrição</Text>
            <TextInput
              style={[styles.input, styles.textArea]}
