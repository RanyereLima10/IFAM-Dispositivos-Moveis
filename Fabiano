import React, { useState } from 'react';
import { View, Text, TextInput, TouchableOpacity, StyleSheet, Alert,
StatusBar } from 'react-native';

export default function App() {
// Estado do saldo atual simulado na conta do usuário
const [saldoAtual, setSaldoAtual] = useState(1000.00);
// Estado para capturar o valor que o usuário deseja sacar
const [valorSaqueInput, setValorSaqueInput] = useState('');

function handleRealizarSaque() {
// Converte o texto digitado para número decimal
const valorSaque = parseFloat(valorSaqueInput);

try {
// Validação 1: Campo vazio ou entrada inválida
if (!valorSaqueInput || isNaN(valorSaque)) {
throw new Error("Por favor, informe um valor numérico para o
saque.");
}

// Validação 2: Valor menor ou igual a zero
if (valorSaque <= 0) {
throw new Error("O valor do saque deve ser maior que zero.");
}
// Validação 3: Condicional para checar se há saldo suficiente
if (valorSaque > saldoAtual) {
throw new Error("Saldo insuficiente para realizar esta
transação.");
}

// Operação matemática de subtração para atualizar o saldo
const novoSaldo = saldoAtual - valorSaque;
setSaldoAtual(novoSaldo);
Alert.alert(
"Saque Concluído",

`R$ ${valorSaque.toFixed(2)} sacado com sucesso! \nNovo saldo:
R$ ${novoSaldo.toFixed(2)} 💸`
);
setValorSaqueInput(''); // Limpa o campo após o sucesso

} catch (error) {
// Captura e exibe qualquer erro gerado no bloco try
Alert.alert("Transação Recusada", error.message);

} finally {
// Executado sempre após o término do bloco de tentativa
console.log("Conexão com o sistema bancário encerrada.");
}
}

return (
