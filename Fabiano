import React, { useState } from 'react';
import { View, Text, TextInput, TouchableOpacity, StyleSheet, Alert,
StatusBar } from 'react-native';

export default function App() {
// Estado para capturar a nota digitada pelo usuário
const [notaInput, setNotaInput] = useState('');

function handleValidarNota() {
// Converte o texto digitado para número decimal
const nota = parseFloat(notaInput);

try {
// Validação básica: Campo vazio ou texto que não é número
if (!notaInput || isNaN(nota)) {
throw new Error("Por favor, digite uma nota válida.");
}

// Regra 1: Nota menor que 0 → erro
if (nota < 0) {
throw new Error("Nota menor que 0 é inválida.");
}

// Regra 2: Nota maior que 10 → erro
if (nota > 10) {
throw new Error("Nota maior que 10 é inválida.");
}

// Regra 3: Nota entre 0 e 10 → exibir nota válida
Alert.alert("Nota Válida", `A nota ${nota.toFixed(1)} foi
registrada com sucesso! 🎓`);
setNotaInput(''); // Limpa o campo após o sucesso

} catch (error) {
// Captura e exibe qualquer erro gerado no bloco try (menor que 0
ou maior que 10)
Alert.alert("Erro de Nota", error.message);

} finally {
// Executa sempre ao final do processo
console.log("Sistema de notas atualizado.");
}
}

return (
<View style={styles.container}>
<StatusBar barStyle="light-content" backgroundColor="#0F172A" />

{/* Título do Projeto */}
<Text style={styles.title}>Validação de Nota</Text>

{/* Subtítulo Instrutivo */}
<Text style={styles.subtitle}>
Insira uma nota de 0 a 10 para verificar se ela cumpre os
requisitos do sistema escolar.
</Text>

{/* Campo de Entrada (Input) */}
<TextInput
style={styles.input}
placeholderTextColor="#64748B"
keyboardType="numeric" // Abre o teclado de números e pontos
value={notaInput}

onChangeText={setNotaInput}
/>

{/* Botão de Ação */}
<TouchableOpacity style={styles.button}
onPress={handleValidarNota}>
<Text style={styles.buttonText}>Validar Nota</Text>
</TouchableOpacity>
</View>
);
}

