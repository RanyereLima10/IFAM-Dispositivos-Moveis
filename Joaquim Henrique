import React, { useState } from 'react';
import {
  View,
  Text,
  TextInput,
  Button,
  StyleSheet,
} from 'react-native';


export default function App() {
  const [saldo, setSaldo] = useState('');
  const [saque, setSaque] = useState('');
  const [resultado, setResultado] = useState('');


  const realizarSaque = () => {
    try {
      const saldoAtual = Number(saldo);
      const valorSaque = Number(saque);


      if (isNaN(saldoAtual) || isNaN(valorSaque)) {
        throw new Error('Digite valores válidos.');
      }


      if (saldoAtual < 0 || valorSaque < 0) {
        throw new Error('Os valores não podem ser negativos.');
      }


      if (valorSaque > saldoAtual) {
        throw new Error('Saldo insuficiente para realizar o saque.');
      }


      // Operação matemática
      const novoSaldo = saldoAtual - valorSaque;


      setResultado(
        `Saque realizado com sucesso!\nSaldo restante: R$ ${novoSaldo.toFixed(
          2
        )}`
      );
    } catch (erro) {
      setResultado(`Erro: ${erro.message}`);
    } finally {
      console.log('Operação de saque finalizada.');
    }
  };


  return (
    <View style={styles.container}>
      <Text style={styles.titulo}>Saque Bancário</Text>


      <TextInput
        style={styles.input}
        placeholder="Saldo atual"
        keyboardType="numeric"
        value={saldo}
        onChangeText={setSaldo}
      />


      <TextInput
        style={styles.input}
        placeholder="Valor do saque"
        keyboardType="numeric"
        value={saque}
        onChangeText={setSaque}
      />


      <Button title="Realizar Saque" onPress={realizarSaque} />


      <Text style={styles.resultado}>{resultado}</Text>
    </View>
  );
}


