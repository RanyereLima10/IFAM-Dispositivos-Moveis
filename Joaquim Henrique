  // FUNÇÃO: CADASTRAR OU ATUALIZAR PRODUTO
  // ============================================================================

  const cadastrarProduto = () => {

    // Executa validação
    if (!validarFormulario()) {
      return;
    }

    // Cria objeto do produto
    const novoProduto = {
      id: editandoId || Date.now().toString(),
      nome: nome.trim(),
      preco: parseFloat(preco).toFixed(2),
      categoria,
      descricao: descricao.trim(),
    };

    // Verifica se está editando
    if (editandoId) {

      // Atualiza produto
      const listaAtualizada = produtos.map((item) =>
        item.id === editandoId ? novoProduto : item
      );

      setProdutos(listaAtualizada);

      Alert.alert(
        'Sucesso',
        'Produto atualizado com sucesso!'
      );

    } else {

      // Adiciona novo produto
      setProdutos([...produtos, novoProduto]);

      Alert.alert(
        'Sucesso',
        'Produto cadastrado com sucesso!'
      );
    }

    // Limpa formulário
    limparCampos();
  };

  // ============================================================================
  // FUNÇÃO: EDITAR PRODUTO
  // ============================================================================

  const editarProduto = (produto) => {

    setNome(produto.nome);
    setPreco(produto.preco.toString());
    setCategoria(produto.categoria);
    setDescricao(produto.descricao);

    setEditandoId(produto.id);
  };

  // ============================================================================
  // FUNÇÃO: DELETAR PRODUTO
  // ============================================================================

  const deletarProduto = (id) => {

    Alert.alert(
      'Confirmar Exclusão',
      'Deseja realmente excluir este produto?',
      [
        {
          text: 'Cancelar',
          style: 'cancel',
        },

        {
          text: 'Excluir',
          style: 'destructive',

          onPress: () => {

            const novaLista = produtos.filter(
              (item) => item.id !== id
            );

            setProdutos(novaLista);

            Alert.alert(
              'Sucesso',
              'Produto removido com sucesso!'
            );
          },
        },
      ]
    );
  };

  // ============================================================================
  // CATEGORIAS DISPONÍVEIS
  // ============================================================================

  const categorias = [
  'Eletrônicos',
  'Roupas',
  'Alimentos',
  'Móveis',
  'Beleza',
  'Outros',
];

  // ============================================================================
  // RENDERIZAÇÃO
  // ============================================================================

  return (

    <ScrollView
      style={styles.container}
      showsVerticalScrollIndicator={false}
    >

      {/* HEADER */}
      <View style={styles.header}>

        <Text style={styles.titulo}>
          Cadastro de Produtos
        </Text>

        <Text style={styles.subtitulo}>
          Gerencie seus produtos de forma simples e organizada
        </Text>
      </View>

      {/* FORMULÁRIO */}
      <View style={styles.formulario}>

        {/* Nome */}
        <Text style={styles.label}>
          Nome do Produto *
        </Text>

        <TextInput
          style={styles.input}
          placeholder="Digite o nome do produto"
          placeholderTextColor="#999"
          value={nome}
          onChangeText={setNome}
        />

        {/* Preço */}
        <Text style={styles.label}>
          Preço *
        </Text>

        <TextInput
          style={styles.input}
          placeholder="Digite o preço"
          placeholderTextColor="#999"
          value={preco}
          onChangeText={setPreco}
          keyboardType="decimal-pad"
        />

        {/* CATEGORIA COM PICKER */}
        <Text style={styles.label}>
          Categoria *
        </Text>

        <View style={styles.pickerContainer}>

          <Picker
            selectedValue={categoria}
            onValueChange={(itemValue) =>
              setCategoria(itemValue)
            }
            style={styles.picker}
          >

            {categorias.map((item) => (

              <Picker.Item
                key={item}
                label={item}
                value={item}
              />
            ))}

          </Picker>
        </View>

        {/* Descrição */}
        <Text style={styles.label}>
          Descrição
        </Text>

        <TextInput
          style={[styles.input, styles.textArea]}
          placeholder="Digite a descrição do produto"
          placeholderTextColor="#999"
          value={descricao}
          onChangeText={setDescricao}
          multiline
          numberOfLines={4}
        />

        {/* BOTÃO CADASTRAR */}
        <TouchableOpacity
          style={styles.botaoCadastrar}
          onPress={cadastrarProduto}
        >

          <Text style={styles.textoBotao}>
            {editandoId
              ? 'ATUALIZAR PRODUTO'
              : 'CADASTRAR PRODUTO'}
          </Text>
        </TouchableOpacity>

        {/* BOTÃO LIMPAR */}
        <TouchableOpacity
          style={styles.botaoLimpar}
          onPress={limparCampos}
        >

          <Text style={styles.textoBotao}>
            LIMPAR CAMPOS
          </Text>
        </TouchableOpacity>
      </View>

      {/* LISTA DE PRODUTOS */}
      <View style={styles.listaContainer}>

        <Text style={styles.listaTitulo}>
          Produtos Cadastrados
        </Text>

        {/* Verifica se existem produtos */}
        {produtos.length === 0 ? (

          <View style={styles.emptyState}>

            <Text style={styles.emptyStateText}>
              Nenhum produto cadastrado ainda.
            </Text>

          </View>

        ) : (

          <FlatList
            data={produtos}
            scrollEnabled={false}
            keyExtractor={(item) => item.id}

            renderItem={({ item }) => (

              <View style={styles.card}>

                {/* Nome */}
                <Text style={styles.nomeProduto}>
                  {item.nome}
                </Text>

                {/* Preço */}
                <Text style={styles.precoProduto}>
                  R$ {item.preco}
                </Text>

                {/* Categoria */}
                <Text style={styles.info}>
                  📦 Categoria: {item.categoria}
                </Text>

                {/* Descrição */}
                <Text style={styles.info}>
                  📝 {item.descricao || 'Sem descrição'}
                </Text>

                {/* Área dos botões */}
                <View style={styles.areaBotoes}>

                  {/* Editar */}
                  <TouchableOpacity
                    style={[
                      styles.botaoAcao,
                      styles.botaoEditar
                    ]}
                    onPress={() => editarProduto(item)}
                  >

                    <Text style={styles.textoBotao}>
                      EDITAR
                    </Text>
                  </TouchableOpacity>

                  {/* Excluir */}
                  <TouchableOpacity
                    style={[
                      styles.botaoAcao,
                      styles.botaoExcluir
                    ]}
                    onPress={() => deletarProduto(item.id)}
                  >

                    <Text style={styles.textoBotao}>
                      EXCLUIR
                    </Text>
                  </TouchableOpacity>
                </View>
              </View>
            )}
          />
        )}
      </View>
    </ScrollView>
  );
}

