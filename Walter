export function LayoutExtremos() {
  return (
    <View style={stylesExtremos.container}>
      <View style={stylesExtremos.camadaExtrema}>
        <Text style={[stylesExtremos.caixa, { backgroundColor: '#BAFFC9' }]}>B</Text>
