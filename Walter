// 2. LAYOUT ÁRVORE
// Descrição: Construção de pirâmide visual através de linhas horizontais centralizadas.

export function LayoutArvore() {
  return (
    <View style={stylesArvore.container}>
      <View style={stylesArvore.linha}><Text style={[stylesArvore.caixa, { backgroundColor: '#FFDFBA' }]}>A</Text></View>
      <View style={stylesArvore.linha}>
        <Text style={[stylesArvore.caixa, { backgroundColor: '#BAFFC9' }]}>B</Text>
        <Text style={[stylesArvore.caixa, { backgroundColor: '#BAE1FF' }]}>C</Text>
      </View>
      <View style={stylesArvore.linha}>
        <Text style={[stylesArvore.caixa, { backgroundColor: '#FFFFBA' }]}>D</Text>
        <Text style={[stylesArvore.caixa, { backgroundColor: '#E0BBE4' }]}>E</Text>
        <Text style={[stylesArvore.caixa, { backgroundColor: '#FFB3BA' }]}>F</Text>
      </View>
      <View style={stylesArvore.linha}>
        <Text style={[stylesArvore.caixa, { backgroundColor: '#B2F7EF' }]}>G</Text>
        <Text style={[stylesArvore.caixa, { backgroundColor: '#F7D1CD' }]}>H</Text>
