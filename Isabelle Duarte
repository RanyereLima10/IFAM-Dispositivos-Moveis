// Importa o React e o Hook useState para gerenciar estados
import React, { useState } from 'react';

// Importa os componentes necessários do React Native
import {
  View,
  Text,
  TextInput,
  TouchableOpacity,
  StyleSheet,
  ScrollView,
  Alert,
} from 'react-native';

// Componente principal da aplicação
export default function App() {

  // Estados para armazenar os dados digitados pelo usuário
  const [titulo, setTitulo] = useState('');
  const [autor, setAutor] = useState('');
  const [genero, setGenero] = useState('');
  const [ano, setAno] = useState('');
  const [sinopse, setSinopse] = useState('');

  // Estado que armazenará todos os livros cadastrados
  const [livros, setLivros] = useState([]);

  // Função responsável por cadastrar um novo livro
  const cadastrarLivro = () => {

    // Verifica se algum campo está vazio
    if (
      titulo.trim() === '' ||
      autor.trim() === '' ||
      genero.trim() === '' ||
      ano.trim() === '' ||
      sinopse.trim() === ''
    ) {
      Alert.alert('Erro', 'Preencha todos os campos!');
      return;
    }

    // Verifica se o ano possui apenas números e 4 dígitos
    if (isNaN(ano) || ano.length !== 4) {
      Alert.alert('Erro', 'Digite um ano válido!');
      return;
    }

    // Cria um objeto contendo os dados do livro
    const novoLivro = {
      id: Date.now(), // Gera um ID único usando data e hora atuais
      titulo,
      autor,
      genero,
      ano,
      sinopse,
    };

    // Adiciona o novo livro ao array de livros
    setLivros([...livros, novoLivro]);

    // Limpa os campos do formulário
    limparCampos();

    // Exibe mensagem de sucesso
    Alert.alert('Sucesso', 'Livro cadastrado!');
  };

  // Função para limpar todos os campos do formulário
  const limparCampos = () => {
    setTitulo('');
    setAutor('');
    setGenero('');
    setAno('');
    setSinopse('');
  };

  // Função para excluir um livro da lista
  const excluirLivro = (id) => {

    // Mantém apenas os livros com ID diferente do selecionado
    setLivros(livros.filter((livro) => livro.id !== id));
  };

  return (

    // ScrollView permite rolagem caso o conteúdo ultrapasse a tela
    <ScrollView style={styles.container}>

      {/* Título principal */}
      <Text style={styles.tituloPrincipal}>
        Cadastro de Livros
      </Text>

      {/* Campo Título */}
      <Text style={styles.label}>Título do Livro *</Text>

      <TextInput
        style={styles.input}
        placeholder="Digite o título"
        placeholderTextColor="#777"
        value={titulo}
        onChangeText={setTitulo}
      />

      {/* Campo Autor */}
      <Text style={styles.label}>Autor *</Text>

      <TextInput
        style={styles.input}
        placeholder="Digite o autor"
        placeholderTextColor="#777"
        value={autor}
        onChangeText={setAutor}
      />

      {/* Seleção de gênero */}
      <Text style={styles.label}>Gênero *</Text>

      <View style={styles.generos}>

        {/* Cria automaticamente os botões de gênero */}
        {['Romance', 'Fantasia', 'Ficção', 'Outros'].map((item) => (

          <TouchableOpacity
            key={item}
            style={[
              styles.generoBtn,

              // Destaca o gênero selecionado
              genero === item && styles.generoSelecionado,
            ]}
            onPress={() => setGenero(item)}
          >
            <Text
              style={[
                styles.generoTexto,

                // Altera a cor do texto do gênero selecionado
                genero === item &&
                  styles.generoTextoSelecionado,
              ]}
            >
              {item}
            </Text>
          </TouchableOpacity>
        ))}
      </View>

      {/* Campo Ano */}
      <Text style={styles.label}>Ano de Publicação *</Text>

      <TextInput
        style={styles.input}
        placeholder="Ex: 2025"
        placeholderTextColor="#777"
        keyboardType="numeric"
        value={ano}
        onChangeText={setAno}
      />

      {/* Campo Sinopse */}
      <Text style={styles.label}>Sinopse *</Text>

      <TextInput
        style={styles.textArea}
        placeholder="Digite uma breve sinopse"
        placeholderTextColor="#777"
        multiline
        numberOfLines={4}
        value={sinopse}
        onChangeText={setSinopse}
      />

      {/* Botão de cadastro */}
      <TouchableOpacity
        style={styles.btnCadastrar}
        onPress={cadastrarLivro}
      >
        <Text style={styles.textoBotao}>
          CADASTRAR
        </Text>
      </TouchableOpacity>

      {/* Botão de limpar formulário */}
      <TouchableOpacity
        style={styles.btnLimpar}
        onPress={limparCampos}
      >
        <Text style={styles.textoBotao}>
          LIMPAR
        </Text>
      </TouchableOpacity>

      {/* Título da lista */}
      <Text style={styles.listaTitulo}>
        Livros Cadastrados
      </Text>

      {/* Caso não existam livros cadastrados */}
      {livros.length === 0 ? (
        <Text style={styles.semLivros}>
          Nenhum livro cadastrado.
        </Text>
      ) : (

        // Percorre o array e exibe um card para cada livro
        livros.map((livro) => (

          <View key={livro.id} style={styles.card}>

            {/* Título do livro */}
            <Text style={styles.cardTitulo}>
              {livro.titulo}
            </Text>

            {/* Autor */}
            <Text style={styles.cardTexto}>
              Autor: {livro.autor}
            </Text>

            {/* Gênero */}
            <Text style={styles.cardTexto}>
              Gênero: {livro.genero}
            </Text>

            {/* Ano */}
            <Text style={styles.cardTexto}>
              Ano: {livro.ano}
            </Text>

            {/* Sinopse */}
            <Text style={styles.cardSinopse}>
              {livro.sinopse}
            </Text>

            {/* Botão para excluir o livro */}
            <TouchableOpacity
              style={styles.btnExcluir}
              onPress={() => excluirLivro(livro.id)}
            >
              <Text style={styles.textoBotao}>
                EXCLUIR
              </Text>
            </TouchableOpacity>

          </View>
        ))
      )}
    </ScrollView>
  );
}

